from collections import OrderedDict

# Create an OrderedDict to track items in order of first appearance
inventory = OrderedDict()
n = int(input())

for _ in range(n):
    # Split input and handle item names with multiple spaces (e.g., BANANA FRIES)
    data = input().rsplit(' ', 1)
    item_name = data[0]
    price = int(data[1])
    
    # Update the net price in the dictionary
    if item_name in inventory:
        inventory[item_name] += price
    else:
        inventory[item_name] = price

# Print the results in the order they were first inserted
for item, net_price in inventory.items():
    print(f"{item} {net_price}")
