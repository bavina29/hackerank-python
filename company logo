from collections import Counter

if __name__ == '__main__':
    s = input().strip()
    
    # Get counts of all characters
    counts = Counter(s)
    
    # Sort by:
    # 1. Negative count (for descending order)
    # 2. Character (for alphabetical order in case of ties)
    sorted_chars = sorted(counts.items(), key=lambda x: (-x[1], x[0]))
    
    # Print the top 3
    for char, count in sorted_chars[:3]:
        print(f"{char} {count}")
