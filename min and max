# Enter your code here. Read input from STDIN. Print output to STDOUT
import numpy

# Read N and M
n, m = map(int, input().split())

# Read the 2D array
storage = numpy.array([input().split() for _ in range(n)], int)

# Find min along axis 1, then the max of that result
min_axis_1 = numpy.min(storage, axis=1)
print(numpy.max(min_axis_1))
