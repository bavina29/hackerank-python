# Enter your code here. Read input from STDIN. Print output to STDOUT
# Read the group size K
k = int(input())

# Read the room numbers and convert to a list of integers
room_numbers = list(map(int, input().split()))

# Create a set of unique room numbers
unique_rooms = set(room_numbers)

# Calculate the Captain's room using the sum property:
# ((Sum of Unique Rooms * K) - (Sum of All Rooms)) // (K - 1)
captains_room = ((sum(unique_rooms) * k) - sum(room_numbers)) // (k - 1)

print(captains_room)
